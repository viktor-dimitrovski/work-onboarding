# Ops scripts configuration (do not commit your real ops.env)

############################################
# SSH to VPS
############################################
OPS_SSH_HOST=your.vps.ip.or.host
OPS_SSH_USER=deploy
OPS_SSH_PORT=22
# Optional key file. Leave empty to use ssh-agent/default key.
# .ppk (PuTTY): used directly with plink/pscp if PuTTY is installed; otherwise converted to OpenSSH via puttygen.
# Use a native Windows path, e.g.: OPS_SSH_KEYFILE=C:\Users\you\.ssh\hetzner_deploy.ppk
# Tip: To avoid typing the .ppk passphrase 3–4 times per sync, start Pageant (PuTTY agent), add your .ppk key once; then plink/pscp use it without prompting.
OPS_SSH_KEYFILE=

############################################
# VPS paths / services
############################################
# Repo root on the VPS (this repo is expected to exist there)
# Example (solvebox-hub): /opt/apps/solvebox-hub
OPS_REMOTE_APP_DIR=/opt/apps/solvebox-hub

# systemd services (created by deploy/ubuntu scripts)
OPS_BACKEND_SERVICE=solvebox-hub-backend
OPS_FRONTEND_SERVICE=solvebox-hub-frontend

############################################
# Local database connection (source for backup)
############################################
# Prefer a plain postgres URL. If you paste SQLAlchemy URL with +psycopg, the script will normalize it.
OPS_LOCAL_DATABASE_URL=postgresql://your_db_user:your_db_password@127.0.0.1:5432/your_db_name

############################################
# Remote backup directory (on VPS)
############################################
# Dump is uploaded here; restore-db.sh reads from this path.
# Example (solvebox-hub): /var/backups/solvebox-hub/db
OPS_REMOTE_BACKUP_DIR=/var/backups/solvebox-hub/db

############################################
# Server-side app settings
############################################
# Linux user that owns/runs the app (created by deploy/ubuntu/01_install_dependencies.sh)
OPS_APP_USER=solvebox
# Full path to backend.env on the server (written once by deploy/ubuntu scripts)
OPS_REMOTE_BACKEND_ENV=/etc/solvebox-hub/backend.env

############################################
# Optional deploy knobs
############################################
OPS_GIT_BRANCH=main

